#!/bin/bash
# [KSW-HUB-HOOK] Show issue context when switching to ksw/ branch
KSW_YAML="ksw.yaml"
[ -f "$KSW_YAML" ] || exit 0

command -v yq >/dev/null 2>&1 || exit 0

BRANCH=$(git branch --show-current)
if [[ "$BRANCH" =~ ^ksw/([0-9]+)- ]]; then
  ID="${BASH_REMATCH[1]}"
  PLATFORM=$(yq -r '.instance.platform' "$KSW_YAML")
  echo "=== KSW Issue #$ID ==="
  if [ "$PLATFORM" = "gitlab" ]; then
    command -v glab >/dev/null 2>&1 || exit 0
    glab issue view "$ID" --comments=false 2>/dev/null | head -10
  elif [ "$PLATFORM" = "github" ]; then
    command -v gh >/dev/null 2>&1 || exit 0
    gh issue view "$ID" 2>/dev/null | head -10
  fi
fi
