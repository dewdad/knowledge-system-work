#!/bin/bash
# [KSW-HUB-HOOK] Auto-append KSW issue reference on hub issue branches
KSW_YAML="ksw.yaml"
[ -f "$KSW_YAML" ] || exit 0

command -v yq >/dev/null 2>&1 || exit 0

AUTO_REF=$(yq -r '.coordination.auto_issue_ref // true' "$KSW_YAML")
[ "$AUTO_REF" = "true" ] || exit 0

BRANCH=$(git branch --show-current)
# Accept ksw/<ID>-* (preferred) or legacy issue/<ID>-* during the 0.6.x grace period.
if [[ "$BRANCH" =~ ^(ksw|issue)/([0-9]+)- ]]; then
  ID="${BASH_REMATCH[2]}"
  if ! grep -q "KSW #$ID" "$1"; then
    echo "" >> "$1"
    echo "(KSW #$ID)" >> "$1"
  fi
fi
