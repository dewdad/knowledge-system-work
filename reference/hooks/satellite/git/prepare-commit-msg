#!/bin/bash
# [KSW-SAT-HOOK] Auto-append KSW issue reference on issue branches
KSW_LINK=".ksw-link.yaml"
[ -f "$KSW_LINK" ] || exit 0

command -v yq >/dev/null 2>&1 || exit 0

AUTO_REF=$(yq -r '.preferences.auto_issue_ref // true' "$KSW_LINK")
[ "$AUTO_REF" = "true" ] || exit 0

BRANCH=$(git branch --show-current)
if [[ "$BRANCH" =~ ^issue/([0-9]+)- ]]; then
  ID="${BASH_REMATCH[1]}"
  if ! grep -q "KSW #$ID" "$1"; then
    echo "" >> "$1"
    echo "(KSW #$ID)" >> "$1"
  fi
fi
